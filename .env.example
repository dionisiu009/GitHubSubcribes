# =============================================================================
# GitHub Release Notification API — змінні середовища
# Скопіюй у .env та заповни значення
# =============================================================================

# ---- HTTP сервер ----
HTTP_PORT=8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s

# ---- Застосунок ----
APP_ENV=production              # development | production
APP_BASE_URL=https://your-domain.com
LOG_LEVEL=info                  # debug | info | warn | error

# ---- PostgreSQL ----
POSTGRES_HOST=postgres          # назва сервісу в docker-compose
POSTGRES_PORT=5432
POSTGRES_USER=notify_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=notify_db
POSTGRES_SSLMODE=disable        # у prod за proxy змінити на require
POSTGRES_MAX_OPEN_CONNS=25
POSTGRES_MAX_IDLE_CONNS=10
POSTGRES_CONN_MAX_LIFETIME=5m

MIGRATION_PATH=migrations       # шлях до sql-файлів міграцій

# ---- Redis ----
REDIS_HOST=redis                # назва сервісу в docker-compose
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB=0
REDIS_CACHE_TTL=10m             # TTL кешу відповідей GitHub API

# ---- GitHub API ----
# Без токена: 60 запитів/год. З токеном: 5000 запитів/год.
# Створити: https://github.com/settings/tokens → repo (read-only)
GITHUB_KEY=ghp_your_personal_access_token
GITHUB_SCAN_INTERVAL=5m        # інтервал опитування GitHub

# ---- SMTP ----
# Dev: використовуй Mailpit (SMTP_HOST=mailpit, SMTP_PORT=1025)
# Prod: вкажи реальний SMTP (Gmail, SendGrid, Postmark тощо)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM=noreply@your-domain.com
SMTP_USE_TLS=true
